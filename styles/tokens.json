{
  "color": {
    "burn": {
      "fill": {
        "healthy": "#22c55e",
        "warning": "#f59e0b",
        "alert": "#f97316",
        "critical": "#ef4444"
      },
      "track": "#2a3148",
      "pulse": {
        "keyframes": "burn-pulse-critical",
        "duration": "1400ms",
        "easing": "cubic-bezier(0.4,0,0.6,1)",
        "animation": "burn-pulse-critical 1400ms cubic-bezier(0.4,0,0.6,1) infinite"
      },
      "breakpoints": {
        "warning": 0.6,
        "alert": 0.8,
        "critical": 0.95
      }
    }
  }
}
