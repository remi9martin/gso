# Paperclip control plane — required at runtime once we wire up live data.
# Leave blank for local dev; CI runs do not exercise these.
PAPERCLIP_API_URL=
PAPERCLIP_API_KEY=
PAPERCLIP_COMPANY_ID=

# Shared secret accepted by POST /api/canvas/refresh — the webhook the CTO
# calls to invalidate the Org Canvas cache. Leave blank to disable refresh.
CANVAS_REFRESH_TOKEN=

# Bearer token clients send to /api/memory/mcp. Leave blank to disable the
# MCP endpoint entirely (handler returns 503). Required for GSO-71.
MEMORY_MCP_BEARER_TOKEN=

# Upstream deploy-memory api.php URL — defaults to the production deploy.
# Override for local dev or a staging mirror.
GSO_MEMORY_API_URL=
# Tokens the MCP proxy presents to api.php. Both must be set for the
# endpoint to function; map to $READ_TOKEN / $SYNC_TOKEN in
# deploy-memory/config.php.
GSO_MEMORY_READ_TOKEN=
GSO_MEMORY_SYNC_TOKEN=

# L1 CONSOLIDATOR /api/intake (GSO-124). projectId is the Intake project's id
# under this company. assigneeUserId is the user that owns new Draft issues
# (Remi/CEO on the local-board instance: "local-board").
GSO_INTAKE_PROJECT_ID=
GSO_INTAKE_ASSIGNEE_USER_ID=
# Optional: a separate user id for /intake UI submissions. Falls back to
# GSO_INTAKE_ASSIGNEE_USER_ID when unset.
GSO_INTAKE_UI_USER_ID=

# Optional: surface a friendlier version string in /api/healthz.
GIT_COMMIT_SHA=
